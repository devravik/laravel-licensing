<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd" bootstrap="vendor/autoload.php" colors="true">
  <testsuites>
    <testsuite name="Unit">
      <directory>tests/Unit</directory>
    </testsuite>
    <testsuite name="Feature">
      <directory>tests/Feature</directory>
    </testsuite>
  </testsuites>
  <php>
    <env name="APP_ENV" value="testing"/>
    <env name="TEST_DB_DRIVER" value="mysql"/>
    <env name="TEST_DB_HOST" value="127.0.0.1"/>
    <env name="TEST_DB_PORT" value="3306"/>
    <env name="TEST_DB_DATABASE" value="laravel_licensing_test"/>
    <env name="TEST_DB_USERNAME" value="root"/>
    <env name="TEST_DB_PASSWORD" value=""/>
    <env name="BCRYPT_ROUNDS" value="4"/>
  </php>
  <source>
    <include>
      <directory suffix=".php">src</directory>
    </include>
  </source>
</phpunit>
